# ══════════════════════════════════════════════
# PORQUIM — variáveis de ambiente
# Copie este arquivo para .env e preencha tudo
# ══════════════════════════════════════════════

# === Evolution API (WhatsApp) ===
EVOLUTION_API_URL=https://evolution-api-production-d600.up.railway.app
EVOLUTION_API_KEY=porquim123
EVOLUTION_INSTANCE=porquim

# === Grok API (IA principal) ===
GROK_API_KEY=xai-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# === OpenAI (áudio e foto) ===
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# === PostgreSQL (Railway) ===
DATABASE_URL=postgresql://postgres:senha@host.railway.internal:5432/railway

# === Mercado Pago ===
# Access Token de PRODUÇÃO — painel do MP → Credenciais → Produção
# https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000

# Webhook Secret — gerado no painel de webhooks do MP
# https://www.mercadopago.com.br/developers/panel/webhooks
# Após criar o webhook com URL: https://SEU_APP.railway.app/webhook/pagamento
MP_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === WhatsApp do Bot ===
# Número do bot com DDI — sem + e sem espaços
BOT_WHATSAPP_NUMBER=5531984686982

# === Servidor ===
PORT=8080

# === Reset de dados (segurança) ===
RESET_SECRET=porquim-reset-2026
